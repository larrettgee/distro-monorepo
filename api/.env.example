# Server
PORT=3001
NODE_ENV=development

# Swagger / API docs
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# YouTube Data API v3
# Create a key at https://console.cloud.google.com/ (enable "YouTube Data API v3")
YOUTUBE_API_KEY=
YOUTUBE_API_BASE_URL=https://www.googleapis.com/youtube/v3
YOUTUBE_TIMEOUT_MS=10000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/distro

# Privy (auth) — copy app secret from app/.env.local
PRIVY_APP_ID=cmqbpkxh5000m0cl9v9ucjxch
PRIVY_APP_SECRET=

# Chain (Arc Testnet) — DistroEscrow
ARC_RPC_URL=https://rpc.testnet.arc.network
CHAIN_ID=5042002
ESCROW_ADDRESS=0x85ea0a0843169f5BcfEafD295790179964cd5320
# ERC-20 USDC token address on Arc testnet (used as the campaign budget token)
USDC_ADDRESS=
USDC_DECIMALS=18
# Operator set on createJob — the address allowed to call recordViews. Must be
# the deployed EscrowViewsReporter (the CRE report receiver), NOT an EOA, since
# CRE writes via the KeystoneForwarder -> reporter. This reporter trusts BOTH
# the production forwarder (deployed DON) and the mock forwarder (local
# `cre simulate --broadcast`), so the same campaigns work for the demo and prod.
ESCROW_OPERATOR_ADDRESS=0x716f3b0b885Cf0Edd1Be17E1DF62560acbCE212F

# CRE — shared secret the Chainlink CRE workflow sends (x-cre-api-key header)
# to fetch the daily on-chain payout batch at GET /cre/batch.
CRE_API_KEY=J0*\4DODt|0refn8PM1wc_VrCz00vbj7

# World ID v4 (https://developer.world.org) — server-side proof verification
WORLD_ID_APP_ID=
WORLD_ID_RP_ID=
WORLD_ID_ACTION=verify-account
# RP signing key (hex) — minted once in the Developer Portal. SERVER-ONLY SECRET.
WORLD_ID_SIGNING_KEY=
WORLD_ID_VERIFY_BASE_URL=https://developer.world.org
# production | staging (staging verifies against the World App simulator)
WORLD_ID_ENVIRONMENT=production
WORLD_ID_TTL_SECONDS=300
WORLD_ID_TIMEOUT_MS=10000
