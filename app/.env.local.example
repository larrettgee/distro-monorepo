# Privy App ID — public, safe to expose. Get it at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=""

# Privy App Secret — SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# Only needed for server-side auth/token verification or server wallets.
PRIVY_APP_SECRET=""

# Public site origin — used to build absolute OpenGraph/Twitter image URLs.
# Defaults to http://localhost:3000; set to your deployed domain in production.
NEXT_PUBLIC_SITE_URL=""
