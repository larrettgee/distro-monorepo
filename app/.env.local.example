# Privy App ID — public, safe to expose. Get it at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=""

# Privy App Secret — SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_.
# Only needed for server-side auth/token verification or server wallets.
PRIVY_APP_SECRET=""

# Public site origin — used to build absolute OpenGraph/Twitter image URLs.
# Defaults to http://localhost:3000; set to your deployed domain in production.
NEXT_PUBLIC_SITE_URL=""

# Cloudflare Stream — SERVER-SIDE ONLY (powers /api/uploads/stream).
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""
CLOUDFLARE_STREAM_MAX_DURATION="7200"

# Cloudflare Stream customer subdomain — PUBLIC (it appears in every playback
# URL). Used to link directly to thumbnails / MP4 downloads without a server
# round-trip. Format: customer-xxxxxxxxxxxxxxxx (no protocol, no domain suffix).
NEXT_PUBLIC_CLOUDFLARE_STREAM_SUBDOMAIN=""

# NestJS backend base URL (proxied via /api/backend/*)
API_URL="http://localhost:3001"
